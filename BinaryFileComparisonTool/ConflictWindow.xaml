<Window x:Class="BinaryFileComparisonTool.ConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BinaryFileComparisonTool"
        mc:Ignorable="d"
        Title="Un conflit a été rencontré" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="ConflitResume" AutoGenerateColumns="False" HorizontalAlignment="Center" Height="334" Margin="0,69,0,0" VerticalAlignment="Top" Width="724" d:ItemsSource="{d:SampleData ItemCount=4}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Adresse" Binding="{Binding Adress}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Rectangle HorizontalAlignment="Left" Height="31" Margin="38,30,0,0" Stroke="Black" VerticalAlignment="Top" Width="393"/>
        <TextBlock HorizontalAlignment="Left" Height="18" Margin="38,37,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="393" FontFamily="Cascadia Code SemiBold" FontSize="14" TextAlignment="Center"><Run Language="fr-fr" Text="Une autre valeur est assignée à cette adresse"/></TextBlock>

    </Grid>
</Window>
