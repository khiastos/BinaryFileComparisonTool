<Window x:Class="BinaryFileComparisonTool.CompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BinaryFileComparisonTool"
        mc:Ignorable="d"
        Title="Comparatifs entre les dumps" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="ComparaisonResume" AutoGenerateColumns="False" HorizontalAlignment="Center" Height="274" Margin="0,69,0,0" VerticalAlignment="Top" Width="724" d:ItemsSource="{d:SampleData ItemCount=4}">
        </DataGrid>
        <Rectangle HorizontalAlignment="Left" Height="31" Margin="38,30,0,0" Stroke="Black" VerticalAlignment="Top" Width="533"/>
        <TextBlock HorizontalAlignment="Left" Height="18" Margin="38,37,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="533" FontFamily="Cascadia Code SemiBold" FontSize="14" TextAlignment="Center"><Run Text="Différences entre les dumps (hors adresse non programmé"/><Run Language="fr-fr" Text="e"/><Run Text=" : 0xFF)"/></TextBlock>
        <Button x:Name="MergeButton" Content="Merger" HorizontalAlignment="Center" Height="33" Margin="0,370,0,0" VerticalAlignment="Top" Width="124" FontFamily="Cascadia Mono" BorderBrush="#FFD01774" Background="#FFF3C4EF" Click="Merge_OnClick"/>
        <TextBlock x:Name="ErrorNumber" HorizontalAlignment="Left" Margin="599,348,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Width="163" Height="38" Foreground="Black"/>
    </Grid>
</Window>
